[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
CN = ESP32_Mastery.local

[v3_req]
subjectAltName = @alt_names
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = ESP32_Mastery.local
DNS.2 = localhost
IP.1 = 127.0.0.1
# Replace this with your current board IP if you want direct-IP HTTPS in Chrome.
IP.2 = 192.168.0.156
